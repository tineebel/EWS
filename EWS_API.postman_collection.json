              "mode": "raw",
              "raw": "{\n  \"toStepOrder\": {{toStepOrder}},\n  \"actorPositionCode\": \"{{approverPositionCode}}\",\n  \"actorEmployeeId\": \"{{approverEmployeeId}}\",\n  \"question\": \"ขอให้ยืนยันข้อมูลเพิ่มเติม...\"\n}",
